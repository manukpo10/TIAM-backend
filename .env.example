# === Local Development ===
# Copy this file to .env and fill in values. Never commit .env.

# Postgres -- local docker (docker compose up -d)
DB_URL=jdbc:postgresql://localhost:5432/tiam
DB_USERNAME=tiam
DB_PASSWORD=tiam

# Postgres -- Supabase (production)
# Get from: Supabase Dashboard -> Project Settings -> Database -> Connection string
# Use the CONNECTION POOLER for Render/serverless:
#   Transaction mode:  jdbc:postgresql://<project>.pooler.supabase.com:6543/postgres
#   Session mode:      jdbc:postgresql://<project>.pooler.supabase.com:5432/postgres
# DB_URL=jdbc:postgresql://<project>.pooler.supabase.com:6543/postgres
# DB_USERNAME=postgres.<project-ref>
# DB_PASSWORD=<your-supabase-db-password>

# JWT
# Generate a secure 256-bit+ secret: openssl rand -hex 32
JWT_SECRET=change-me-minimum-256-bits-random-string
JWT_EXPIRATION_MS=86400000

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# CORS -- comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
